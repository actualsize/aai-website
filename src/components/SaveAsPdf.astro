---
interface Props {
  label?: string;
}
const { label = "Save as PDF" } = Astro.props;
---
<button class="bg-aai-black text-white text-sm font-extrabold uppercase tracking-wider px-6 py-3 flex items-center gap-2 hover:bg-gray-800 transition-colors duration-150">
  <span class="w-4 h-5 border border-white/60 flex items-center justify-center text-[8px]">&#9660;</span>
  {label}
</button>
