---
interface Props {
  currentPage?: number;
  totalPages?: number;
}
const {
  currentPage = 1,
  totalPages = 5,
} = Astro.props;

// Build page numbers to display
function getPageNumbers(current: number, total: number): (number | "...")[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | "...")[] = [1];
  if (current > 3) pages.push("...");
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push("...");
  pages.push(total);
  return pages;
}

const pages = getPageNumbers(currentPage, totalPages);
---
<nav aria-label="Pagination" class="page-frame">
  <div class="flex items-center justify-center gap-1 px-page-margin py-12">
    <!-- Previous -->
    {currentPage > 1 ? (
      <a href="#" class="px-3 py-2 text-sm font-extrabold uppercase hover:underline">← Previous</a>
    ) : (
      <span class="px-3 py-2 text-sm font-extrabold uppercase text-gray-300 cursor-not-allowed">← Previous</span>
    )}

    <!-- Page numbers -->
    {pages.map((page) => (
      page === "..."
        ? <span class="px-2 py-2 text-sm text-gray-400">…</span>
        : page === currentPage
          ? <span class="w-9 h-9 flex items-center justify-center bg-aai-black text-white text-sm font-bold">{page}</span>
          : <a href="#" class="w-9 h-9 flex items-center justify-center text-sm hover:bg-aai-section-bg transition-colors duration-150">{page}</a>
    ))}

    <!-- Next -->
    {currentPage < totalPages ? (
      <a href="#" class="px-3 py-2 text-sm font-extrabold uppercase hover:underline">Next →</a>
    ) : (
      <span class="px-3 py-2 text-sm font-extrabold uppercase text-gray-300 cursor-not-allowed">Next →</span>
    )}
  </div>
</nav>
