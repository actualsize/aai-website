---
interface Props {
  label?: string;
  value?: string;
  descriptor?: string;
}
const {
  label = "SMARTER R&D",
  value = "13%",
  descriptor = "Spend on Software"
} = Astro.props;
---
<div class="flex flex-col gap-2">
  <span class="text-base font-extrabold uppercase">{label}</span>
  <span class="font-serif text-[80px] leading-none font-light">{value}</span>
  <span class="text-xl">{descriptor}</span>
</div>
