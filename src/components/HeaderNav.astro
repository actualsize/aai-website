---
interface Props {
  links?: string[];
}
const { links = ["About", "Membership", "Advocacy", "News & Media", "Industry Insights", "Events"] } = Astro.props;
---
<header class="page-frame bg-aai-white">
  <!-- Utility bar -->
  <div class="h-8 bg-aai-nav-bar w-full"></div>

  <!-- Nav row -->
  <nav class="flex items-center justify-between h-20 px-page-margin">
    <!-- Logo placeholder -->
    <div class="img-placeholder w-40 h-[47px]"></div>

    <!-- Nav links -->
    <ul class="flex gap-8">
      {links.map((link) => (
        <li>
          <a href="#" class="text-sm text-aai-black transition-colors duration-150 hover:text-gray-500 hover:underline">{link}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>
