---
interface CardData {
  category: string;
  title: string;
  body: string;
}
interface Props {
  cards?: CardData[];
}
const { cards = [
  { category: "safety", title: "Recalls", body: "Lorem ipsum dolor sit amet consectetur. Mattis faucibus dignissim malesuada lectus." },
  { category: "technology", title: "Cybersecurity", body: "Lorem ipsum dolor sit amet consectetur. Mattis faucibus dignissim malesuada lectus." },
  { category: "energy", title: "Electrification", body: "Lorem ipsum dolor sit amet consectetur. Mattis faucibus dignissim malesuada lectus." },
]} = Astro.props;
---
<section class="page-frame">
  <div class="flex gap-6 px-page-margin pb-12">
    {cards.map((card) => (
      <div class="group flex-1 flex flex-col gap-3 cursor-pointer transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
        <div class="img-placeholder w-full aspect-[432/340] transition-[filter] duration-200 group-hover:brightness-95"></div>
        <span class="text-base font-extrabold uppercase">{card.category}</span>
        <h3 class="font-serif text-4xl leading-snug font-normal">{card.title}</h3>
        <p class="text-base leading-relaxed">{card.body}</p>
        <a href="#" class="text-base font-extrabold uppercase group-hover:underline">LEARN MORE →</a>
      </div>
    ))}
  </div>
</section>
