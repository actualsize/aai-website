---
interface Props {
  active?: string;
  tags?: string[];
}
const {
  active = "All",
  tags = ["Energy & Environment", "Technology", "Safety", "View all"]
} = Astro.props;
---
<div class="page-frame px-page-margin">
  <div class="flex items-center justify-between bg-aai-filter-bg rounded pl-2.5 pr-[30px] py-2 max-w-[762px]">
    <!-- Active pill -->
    <span class="bg-aai-filter-pill px-4 py-3 text-sm font-extrabold shrink-0">
      {active}
    </span>

    <!-- Tag labels -->
    {tags.map((tag) => (
      <button class="text-sm font-extrabold hover:underline whitespace-nowrap cursor-pointer">
        {tag}
      </button>
    ))}
  </div>
</div>
